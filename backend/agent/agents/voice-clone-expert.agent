tools:
  # ── 优先：GPT-SoVITS 本地工具组（免费、隐私安全）──
  # 注意：sovits_health_check 已移除，系统在调用前已确认服务状态（铁律1）
  - sovits_list_audio_files   # 【必须第一步】查询工作区音频文件，取 workspace_path
  - sovits_tts_and_save       # TTS 合成（必须传 ref_audio_workspace_path）
  - sovits_clone_and_save     # 克隆+合成一体（必须传 ref_audio_workspace_path）
  - sovits_list_models        # 查看可用音色模型
  - sovits_set_model          # 切换音色模型
  # ── 降级：MiniMax 云端工具组（GPT-SoVITS 不可用时，或用户明确要求 MiniMax）──
  - upload_voice_sample       # 上传参考音频 → 获取 file_id（参数名：audio_workspace_path）
  - clone_voice_minimax       # 克隆音色 → 获取 voice_id（参数：file_id + voice_id）
  - list_cloned_voices        # 查询已克隆音色列表
  - synthesize_speech_minimax # TTS 合成（支持克隆音色 voice_id 或内置音色）
  # ── 通用 ──
  - finish_task
max_steps: 10
