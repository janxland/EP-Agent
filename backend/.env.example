# ABC-Agent 后端环境变量配置示例
# 复制此文件为 .env 并填入真实值（.env 已加入 .gitignore）

# ── 必填：LLM 配置 ─────────────────────────────────────────────
# 支持任何 OpenAI 兼容接口（硅基流动 / OpenAI / Azure 等）
LLM_API_KEY=sk-your-llm-api-key
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3

# ── 必填：sky-music-tools 路径 ────────────────────────────────
SKILL_DIR=/app/.workspace/.magic/skills/sky-music-tools

# ── 可选：服务监听地址（默认 0.0.0.0:8080）──────────────────
# APP_ADDR=0.0.0.0:8082

# ── 可选：音频生成 API（未配置时工具返回友好错误）────────────

# MiniMax 官方 API（推荐，有免费额度）
# 获取 Key：https://platform.minimax.io → 账户管理 → 接口密钥
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Suno AI（通过 TTAPI 第三方封装）
# 获取 Key：https://ttapi.io → 注册后在控制台获取
SUNO_API_KEY=
SUNO_BASE_URL=https://api.ttapi.io
