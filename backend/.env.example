# EP-Agent 后端环境变量模板
# 复制为 .env 后填写真实值：cp .env.example .env

# ── LLM（必填）────────────────────────────────────────────────
LLM_API_KEY=your-openai-or-compatible-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ── 服务地址 ──────────────────────────────────────────────────
APP_ADDR=0.0.0.0:8080

# ── 音频生成（可选）──────────────────────────────────────────
# MiniMax 官方 API：https://platform.minimax.io
MINIMAX_API_KEY=

# Suno AI（通过 TTAPI 封装）：https://ttapi.io
SUNO_API_KEY=
SUNO_BASE_URL=https://api.ttapi.io

# ── GPT-SoVITS 高质量音色克隆（可选，需自部署）──────────────
# 部署参考：https://github.com/RVC-Boss/GPT-SoVITS
SOVITS_BASE_URL=
SOVITS_API_KEY=

# ── 存储路径（可选）──────────────────────────────────────────
# 数据库路径（默认 backend/data/ep_agent.db）
# EP_AGENT_DB=/path/to/ep_agent.db

# H5 海报输出目录（默认 /tmp/ep_agent_h5）
# H5_OUTPUT_DIR=/path/to/h5_output

# Session 内存 TTL（秒），默认 2 小时
# SESSION_TTL_SECONDS=7200
