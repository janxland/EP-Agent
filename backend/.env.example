# ═══════════════════════════════════════════════════════════════
#  EP-Agent 环境变量配置示例
#  复制此文件为 .env，填入真实值后启动服务
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── 服务地址 ─────────────────────────────────────────────────────
APP_ADDR=0.0.0.0:8080

# ── LLM 主模型（必填）────────────────────────────────────────────
# 支持 OpenAI 兼容接口（SiliconFlow / DeepSeek / 本地 Ollama 等）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# 备用：直接使用 SiliconFlow 变量名（与上方等价，二选一即可）
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── 工作区目录 ───────────────────────────────────────────────────
ABC_WORKSPACE_DIR=./data/workspace

# ── H5 海报输出目录 ──────────────────────────────────────────────
H5_OUTPUT_DIR=/tmp/ep_agent_h5

# ═══════════════════════════════════════════════════════════════
#  音频生成 API（可选，未配置时对应工具返回友好提示）
# ═══════════════════════════════════════════════════════════════

# ── Suno AI（通过 TTAPI 封装）────────────────────────────────────
# 申请地址：https://ttapi.io
SUNO_API_KEY=
SUNO_BASE_URL=https://api.ttapi.io

# ── MiniMax 官方 API（音色克隆 / TTS / 音乐生成）────────────────
# 申请地址：https://platform.minimax.io
# 用途：音色克隆（clone_voice_minimax）、语音合成（synthesize_speech_minimax）
#       音乐生成（generate_audio_minimax）、歌词生成（generate_lyrics_minimax）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1

# ═══════════════════════════════════════════════════════════════
#  GPT-SoVITS 本地音色克隆服务（推荐，免费无限制）
# ═══════════════════════════════════════════════════════════════
#
#  安装方式（一键安装器）：
#    Mac/Linux: bash EP-Agent/sovits-installer/start.sh
#    Windows:   双击 EP-Agent/sovits-installer/start.bat
#
#  手动安装：
#    git clone https://github.com/RVC-Boss/GPT-SoVITS
#    conda create -n GPTSoVits python=3.10 -y
#    conda activate GPTSoVits
#    bash install.sh --device MPS --source HF-Mirror   # Mac
#    bash install.sh --device CPU --source HF-Mirror   # Linux
#    python webui.py                                    # 启动，默认端口 9872
#
#  Docker 一键部署（推荐）：
#    cd EP-Agent/sovits-installer
#    docker-compose up -d
#    # 安装器 UI：http://localhost:3333
#    # WebUI：    http://localhost:9874
#    # TTS API：  http://localhost:9880/docs  ← 配置此地址
#
#  手动部署：
#    git clone https://github.com/RVC-Boss/GPT-SoVITS
#    conda create -n GPTSoVits python=3.10 -y && conda activate GPTSoVits
#    bash install.sh --device MPS --source HF-Mirror   # Mac
#    bash install.sh --device CPU --source HF-Mirror   # Linux/Docker
#    python api_v2.py -a 0.0.0.0 -p 9880               # 启动 API 服务
#
#  配置说明：
#    SOVITS_BASE_URL  — TTS API 地址（端口 9880，非 WebUI 的 9874）
#    SOVITS_API_KEY   — 鉴权 key（默认不需要，留空即可）
#
#  API 接口规范（已对齐官方 Docker 版）：
#    有参考音频（零样本克隆）→ multipart/form-data，ref_audio_path 字段上传文件
#    无参考音频（默认音色 TTS）→ JSON POST
#
#  功能说明：
#    - 零样本克隆：3-10 秒参考音频即可克隆任意音色，无需训练
#    - 多语言：中文 / 英文 / 日文 / 韩文 / 粤语
#    - 完全本地运行，数据不出本机，免费无限制
#    - 未配置时自动降级到 MiniMax 音色克隆 API
#
SOVITS_BASE_URL=http://localhost:9880
SOVITS_API_KEY=

# ═══════════════════════════════════════════════════════════════
#  前端配置（frontend/.env.local）
# ═══════════════════════════════════════════════════════════════
#
#  以下变量用于前端，请同步写入 frontend/.env.local：
#
#  NEXT_PUBLIC_API_URL=http://localhost:8080
#  NEXT_PUBLIC_WS_URL=ws://localhost:8080
#
# ═══════════════════════════════════════════════════════════════
#  快速启动命令
# ═══════════════════════════════════════════════════════════════
#
#  后端：
#    cd EP-Agent/backend
#    cp .env.example .env  # 填入配置
#    pip install -r requirements.txt
#    python main.py
#
#  前端：
#    cd EP-Agent/frontend
#    cp .env.example .env.local
#    npm install
#    npm run dev
#
#  GPT-SoVITS（可选，音色克隆）：
#    bash EP-Agent/sovits-installer/start.sh
#
# ═══════════════════════════════════════════════════════════════
