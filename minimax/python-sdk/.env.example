# Copy values into your shell or secret manager. The SDK never reads or writes .env files.
MINIMAX_API_KEY=replace-with-your-api-key
# mainland -> https://api.minimaxi.com/v1
# global   -> https://api.minimax.io/v1
MINIMAX_REGION=mainland
# Optional full override, useful for an enterprise gateway or MockTransport tests.
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
